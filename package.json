{
  "name": "nomos-sdk-cli",
  "version": "0.1.0",
  "main": "./dist/index.js",
  "scripts": {
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:e2e": "bun test tests/e2e",
    "test:integration": "bun test tests/integration",
    "test:shell": "./tests/e2e/shell-tests.sh",
    "test:all": "bun run build && bun test && bun run test:shell",
    "test:api": "bun test tests/integration/api.test.ts",
    "build": "bun build src/cli.ts --outfile dist/cli.js --target node --shebang",
    "dev": "bun src/cli.ts",
    "capabilities": "bun src/cli.ts capabilities",
    "sync": "bun scripts/sync-openapi.mjs",
    "generate": "bun scripts/generate-operations.ts",
    "prebuild": "bun run generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Nomos Energy SDK and CLI",
  "type": "module",
  "bin": {
    "nomos": "./dist/cli.js"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  },
  "types": "./dist/index.d.ts"
}
