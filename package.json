{
  "name": "nomos-sdk-cli",
  "version": "0.1.0",
  "main": "./dist/index.js",
  "scripts": {
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:e2e": "bun test tests/e2e",
    "test:integration": "bun test tests/integration",
    "test:shell": "./tests/e2e/shell-tests.sh",
    "test:all": "bun run build && bun test && bun run test:shell",
    "test:api": "bun test tests/integration/api.test.ts",
    "build": "bun build src/cli.ts --outfile dist/cli.js --target node --shebang && bun build src/index.ts --outfile dist/index.js --target node",
    "dev": "bun src/cli.ts",
    "capabilities": "bun src/cli.ts capabilities",
    "sync": "bun scripts/sync-openapi.mjs",
    "generate": "bun scripts/generate-operations.ts",
    "prebuild": "bun run generate",
    "docs:generate": "bun scripts/generate-docs.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "eslint src/",
    "visual-audit": "bun scripts/visual-audit.ts",
    "visual-audit:report": "bun scripts/visual-audit.ts --report"
  },
  "keywords": [
    "nomos",
    "energy",
    "sdk",
    "cli",
    "api"
  ],
  "author": "Nomos Energy",
  "license": "ISC",
  "description": "Nomos Energy SDK and CLI - TypeScript client for the Nomos API",
  "type": "module",
  "bin": {
    "nomos": "./dist/cli.js"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "boxen": "^8.0.1",
    "cli-table3": "^0.6.5",
    "ora": "^8.2.0",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@redocly/cli": "^2.24.1",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "eslint": "^9.22.0",
    "typescript-eslint": "^8.26.1",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4"
  },
  "types": "./dist/index.d.ts",
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
